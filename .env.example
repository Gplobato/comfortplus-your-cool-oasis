# Variáveis públicas do frontend (Vite embute no bundle no build).
# No Cloudflare Workers Builds, cadastre estas mesmas chaves como BUILD VARIABLES.
VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=SUA_CHAVE_PUBLICAVEL

# Opcional — o app atual fala com Supabase diretamente.
# VITE_API_BASE_URL=https://api.seudominio.com

# NÃO coloque aqui:
# - SUPABASE_SERVICE_ROLE_KEY
# - NANOGPT_API_KEY
# - META_APP_SECRET
# Esses secrets ficam só no Supabase/Lovable (Edge Functions).
